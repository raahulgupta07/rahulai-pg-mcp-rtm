# RTM Agent — Environment Variables
# Copy this file to .env and fill in your values

# PostgreSQL connection. Docker compose overrides this with the 'postgres'
# service host. For local (non-Docker) dev, point at your local Postgres:
DATABASE_URL=postgresql://rtm:rtm@localhost:5432/rtm

# OpenRouter API Key (for AI insights — optional, rule-based fallback if not set)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# LLM Model (default: google/gemini-3.1-flash-lite-preview)
LLM_MODEL=google/gemini-3.1-flash-lite-preview

# LLM API Base URL (default: OpenRouter)
LLM_BASE_URL=https://openrouter.ai/api/v1

# JWT Secret Key (change in production)
JWT_SECRET_KEY=rtm-command-center-secret-change-in-prod

# Default Admin Account (created on first run if no users.json exists)
# All other users are created by admin via Settings > Users tab in the UI
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_DISPLAY_NAME=Administrator
